# =============================================================================
# .env.example — Ortam Değişkeni Şablonu
# =============================================================================
# cp .env.example .env → değerleri doldur
# GÜVENLİK: .env dosyasını ASLA git'e commit etme.
# =============================================================================

# ---------------------------------------------------------------------------
# UYGULAMA
# ---------------------------------------------------------------------------
APP_ENV=production
PORT=8080
DATA_DIR=/data

# ---------------------------------------------------------------------------
# HERMES
# ---------------------------------------------------------------------------
HERMES_VERSION=v0.6.0
HERMES_ANALYSIS_HOME=/data/.hermes/analysis
HERMES_EXECUTION_HOME=/data/.hermes/execution
HERMES_WORKSPACE_DIR=/data/workspace
DEFAULT_PROFILE=analysis
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# ZORUNLU SAĞLAYICI — En az biri aktif olmalı
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# OPSİYONEL SAĞLAYICILAR
# ---------------------------------------------------------------------------

# OpenAI-compatible (genel gateway)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# NVIDIA NIM (trade-fast için)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Alibaba DashScope (Qwen)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=

# Z.AI / GLM
ZAI_API_KEY=
ZAI_BASE_URL=

# Moonshot / Kimi
KIMI_API_KEY=
KIMI_BASE_URL=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=

# ---------------------------------------------------------------------------
# SENPI
# ---------------------------------------------------------------------------
SENPI_AUTH_TOKEN=
SENPI_MCP_ENABLED=true

# ---------------------------------------------------------------------------
# OPSİYONEL: Brave Search MCP
# ---------------------------------------------------------------------------
BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# OPSİYONEL: Telegram bot (bildirim için)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# ---------------------------------------------------------------------------
# OPSİYONEL: Admin
# ---------------------------------------------------------------------------
ADMIN_SETUP_TOKEN=
DISABLE_PUBLIC_SETUP=true

# ---------------------------------------------------------------------------
# OPSİYONEL: Backup şifreleme
# ---------------------------------------------------------------------------
BACKUP_ENCRYPTION_PASSPHRASE=

# ---------------------------------------------------------------------------
# RAILWAY SPESIFIK (Railway ortamında otomatik gelir, elle tanımlamayın)
# ---------------------------------------------------------------------------
# RAILWAY_VOLUME_MOUNT_PATH=/data
# RAILWAY_SERVICE_NAME=hermes-senpi-trader
